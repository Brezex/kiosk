# Секреты
SECRET_KEY=change-this-in-production-very-secret-key-min-32-chars

# База данных
DATABASE_URL=sqlite:///./data/zabbix_kiosk.db

# Порт
PORT=8000

# CORS
CORS_ORIGINS=http://localhost,http://localhost:5173,http://localhost:8000

# Zabbix настройки
ZABBIX_TIMEOUT=30
ZABBIX_RETRY_COUNT=3
ZABBIX_RETRY_DELAY=5
ZABBIX_CACHE_TTL=300